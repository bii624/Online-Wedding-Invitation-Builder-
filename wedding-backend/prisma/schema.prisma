// =====================================================================
// WEDDING CARD BUILDER - PRISMA SCHEMA
// Kiến trúc: Single-page (canvas cuộn dài, không phân trang).
//
// Thay đổi so với phiên bản cũ:
//   1. Bỏ CardPage / TemplatePage — CardBlock và TemplateBlock trỏ thẳng
//      vào Card / Template (single-page architecture).
//   2. Bỏ WeddingEvent — người dùng nhập ngày/giờ/địa điểm trực tiếp
//      qua text block / countdown block / map block trên canvas.
//   3. RsvpResponse bỏ eventId — RSVP gắn với toàn bộ thiệp (cardId).
//
// Quy ước:
//   - Model: PascalCase | Field: camelCase | DB table/column: snake_case
//   - updatedAt dùng @updatedAt — Prisma tự cập nhật.
//   - id UUID do Postgres sinh (@default(dbgenerated("gen_random_uuid()"))).
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
// =====================================================================
// ENUMS
// =====================================================================

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  suspended
  unverified
}

enum AuthProvider {
  email
  google
  facebook
}

enum TemplateStatus {
  draft
  published
  archived
}

enum CardStatus {
  draft
  published
  archived
}

/// Loại phần tử (block) kéo-thả tự do trên canvas
enum BlockType {
  text
  image
  shape
  icon
  line
  video
  audio
  countdown // đồng hồ đếm ngược tới ngày cưới — người dùng tự cài targetDate
  map // bản đồ / chỉ đường — người dùng nhập lat/lng/address
  button // nút hành động (mở bản đồ, link RSVP ngoài, v.v.)
  gallery // block hiển thị nhiều ảnh
  rsvp_form // form RSVP nhúng vào canvas
  wishes_wall // khung hiển thị lời chúc
  qr_code
  calendar
}

enum AssetType {
  image
  video
  audio
  font
}

enum GuestSide {
  groom
  bride
  both
}

enum RsvpStatus {
  yes
  no
  maybe
}

/// Loại element có sẵn trong thư viện (admin curate, user tìm kiếm & kéo vào canvas)
enum ElementType {
  icon // icon đơn sắc/đa sắc (hoa, nhẫn, trái tim, chim bồ câu...)
  shape // hình khối cơ bản
  illustration // minh hoạ phức tạp hơn icon
  sticker // sticker trang trí
  frame // khung viền ảnh trang trí
  photo // ảnh stock thật (tab "Stock" / "Thay ảnh nhanh")
}

// =====================================================================
// 1. USERS & PLANS
// =====================================================================

model Plan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String // VD: Free, Premium, Pro
  price        Decimal  @default(0) @db.Decimal(12, 2)
  durationDays Int?     @map("duration_days") // NULL = vĩnh viễn
  maxCards     Int?     @map("max_cards") // NULL = không giới hạn
  features     Json     @default("{}") // {"remove_watermark": true, ...}
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  users           User[]
  templates       Template[]
  libraryElements LibraryElement[]
  cards           Card[]

  @@map("plans")
}

model User {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String?      @unique
  phone                String?      @unique
  passwordHash         String?      @map("password_hash") // NULL nếu đăng nhập qua social
  fullName             String?      @map("full_name")
  avatarUrl            String?      @map("avatar_url")
  authProvider         AuthProvider @default(email) @map("auth_provider")
  providerId           String?      @map("provider_id") // id từ Google/Facebook
  role                 UserRole     @default(user)
  status               UserStatus   @default(unverified)
  currentPlanId        String?      @map("current_plan_id") @db.Uuid
  refreshToken         String?      @map("refresh_token")
  resetPasswordToken   String?      @map("reset_password_token")
  resetPasswordExpires DateTime?    @map("reset_password_expires")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  currentPlan      Plan?            @relation(fields: [currentPlanId], references: [id], onDelete: SetNull)
  cards            Card[]
  assets           Asset[]
  createdTemplates Template[]       @relation("TemplateCreatedBy")
  createdElements  LibraryElement[] @relation("ElementCreatedBy")

  @@index([email])
  @@map("users")
}

// =====================================================================
// 2. THƯ VIỆN ELEMENT CÓ SẴN
//    Admin curate, user TÌM KIẾM (theo tên/tag) và kéo thả vào canvas.
// =====================================================================

model ElementCategory {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String // VD: "Hoa lá", "Khung viền", "Biểu tượng cưới"
  slug     String  @unique
  parentId String? @map("parent_id") @db.Uuid

  parent   ElementCategory?  @relation("ElementCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ElementCategory[] @relation("ElementCategoryTree")
  elements LibraryElement[]

  @@map("element_categories")
}

model LibraryElement {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String?        @map("category_id") @db.Uuid
  name           String // tên để admin quản lý + hiển thị khi hover
  elementType    ElementType    @map("element_type")
  tags           String[]       @default([]) // từ khoá tìm kiếm
  fileUrl        String         @map("file_url") // ảnh/SVG thật
  thumbnailUrl   String?        @map("thumbnail_url")
  width          Float?
  height         Float?
  isRecolorable  Boolean        @default(false) @map("is_recolorable") // SVG đổi màu fill được
  isPremium      Boolean        @default(false) @map("is_premium")
  requiredPlanId String?        @map("required_plan_id") @db.Uuid
  usageCount     Int            @default(0) @map("usage_count")
  status         TemplateStatus @default(draft)
  createdBy      String?        @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  category       ElementCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requiredPlan   Plan?            @relation(fields: [requiredPlanId], references: [id], onDelete: SetNull)
  creator        User?            @relation("ElementCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  templateBlocks TemplateBlock[]
  cardBlocks     CardBlock[]

  @@index([categoryId])
  @@index([status])
  @@index([tags], type: Gin)
  // Tìm kiếm gần đúng theo name cần extension pg_trgm (tạo qua migration thủ công):
  //   CREATE INDEX idx_library_elements_name_trgm
  //     ON library_elements USING GIN (name gin_trgm_ops);
  @@map("library_elements")
}

// =====================================================================
// 3. TEMPLATES — mẫu thiệp do admin thiết kế sẵn (single-page)
// =====================================================================

model TemplateCategory {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String // VD: "Thiệp cưới", "Tối giản", "Hoa văn"
  slug     String  @unique
  parentId String? @map("parent_id") @db.Uuid

  parent    TemplateCategory?  @relation("TemplateCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  TemplateCategory[] @relation("TemplateCategoryTree")
  templates Template[]

  @@map("template_categories")
}

model Template {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String?        @map("category_id") @db.Uuid
  name           String // VD: "Thiệp Cưới 223 Pre"
  slug           String         @unique
  thumbnailUrl   String?        @map("thumbnail_url")
  isPremium      Boolean        @default(false) @map("is_premium")
  requiredPlanId String?        @map("required_plan_id") @db.Uuid
  canvasWidth    Float          @default(414) @map("canvas_width") // mobile-first (px)
  background     Json           @default("{}") // {"type":"color","value":"#fff"} | {"type":"image","url":"..."}
  status         TemplateStatus @default(draft)
  useCount       Int            @default(0) @map("use_count")
  displayOrder   Int            @default(0) @map("display_order")
  createdBy      String?        @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  category     TemplateCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requiredPlan Plan?             @relation(fields: [requiredPlanId], references: [id], onDelete: SetNull)
  creator      User?             @relation("TemplateCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  blocks       TemplateBlock[]
  cards        Card[]

  @@index([categoryId])
  @@index([status])
  @@map("templates")
}

/// Block tự do trong mẫu gốc — trỏ thẳng vào Template (không qua page)
model TemplateBlock {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId      String    @map("template_id") @db.Uuid // ← trực tiếp, không qua page
  sourceElementId String?   @map("source_element_id") @db.Uuid // element gốc từ thư viện (nếu có)
  blockType       BlockType @map("block_type")
  posX            Float     @default(0) @map("pos_x")
  posY            Float     @default(0) @map("pos_y")
  width           Float     @default(100)
  height          Float     @default(100)
  rotation        Float     @default(0)
  zIndex          Int       @default(0) @map("z_index")
  content         Json      @default("{}") // nội dung theo blockType
  style           Json      @default("{}") // màu, font, shadow, animation...
  isLocked        Boolean   @default(false) @map("is_locked")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  template      Template        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sourceElement LibraryElement? @relation(fields: [sourceElementId], references: [id], onDelete: SetNull)
  clonedBlocks  CardBlock[]     @relation("CardBlockSourceTemplateBlock")

  @@index([templateId, zIndex])
  @@map("template_blocks")
}

// =====================================================================
// 4. CARDS — thiệp thực tế của user (single-page)
// =====================================================================

model Card {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  templateId     String?    @map("template_id") @db.Uuid // mẫu gốc đã dùng (NULL = trang trắng)
  slug           String     @unique // URL public: /thiep/<slug>
  title          String // tên nội bộ
  thumbnailUrl   String?    @map("thumbnail_url")
  groomName      String?    @map("groom_name")
  brideName      String?    @map("bride_name")
  status         CardStatus @default(draft)
  isPublic       Boolean    @default(true) @map("is_public")
  accessPassword String?    @map("access_password") // mật khẩu xem thiệp (tùy chọn, nên hash)
  viewCount      Int        @default(0) @map("view_count")
  planId         String?    @map("plan_id") @db.Uuid
  background     Json       @default("{}") // {"type":"color","value":"#fff"} | {"type":"image","url":"..."}
  settings       Json       @default("{}") // nhạc nền, theme màu, font, hạn RSVP...
  publishedAt    DateTime?  @map("published_at")
  expiresAt      DateTime?  @map("expires_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  plan     Plan?          @relation(fields: [planId], references: [id], onDelete: SetNull)
  blocks   CardBlock[]
  guests   Guest[]
  rsvps    RsvpResponse[]
  wishes   Wish[]
  views    CardView[]

  @@index([userId])
  @@index([slug])
  @@index([status])
  @@map("cards")
}

/// Block tự do trên canvas của user — bảng trung tâm của editor kéo-thả.
/// Mọi thao tác (di chuyển, resize, xoay, đổi nội dung) đều ghi vào bảng này.
model CardBlock {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId                String    @map("card_id") @db.Uuid // ← trực tiếp, không qua page
  sourceTemplateBlockId String?   @map("source_template_block_id") @db.Uuid // block gốc khi clone (hỗ trợ "khôi phục mặc định")
  sourceElementId       String?   @map("source_element_id") @db.Uuid // element gốc từ thư viện (nếu kéo trực tiếp)
  blockType             BlockType @map("block_type")
  posX                  Float     @default(0) @map("pos_x")
  posY                  Float     @default(0) @map("pos_y")
  width                 Float     @default(100)
  height                Float     @default(100)
  rotation              Float     @default(0)
  zIndex                Int       @default(0) @map("z_index")
  content               Json      @default("{}")
  style                 Json      @default("{}")
  isLocked              Boolean   @default(false) @map("is_locked")
  isVisible             Boolean   @default(true) @map("is_visible")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  card                Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sourceTemplateBlock TemplateBlock?  @relation("CardBlockSourceTemplateBlock", fields: [sourceTemplateBlockId], references: [id], onDelete: SetNull)
  sourceElement       LibraryElement? @relation(fields: [sourceElementId], references: [id], onDelete: SetNull)

  @@index([cardId, zIndex])
  @@map("card_blocks")
}

// =====================================================================
// 5. KHÁCH MỜI, RSVP, LỜI CHÚC
// =====================================================================

/// Danh sách khách mời (tùy chọn): chủ thiệp quản lý và sinh link cá nhân hóa.
model Guest {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId        String    @map("card_id") @db.Uuid
  name          String
  phone         String?
  groupName     String?   @map("group_name") // VD: "Họ nhà trai", "Bạn cô dâu"
  side          GuestSide @default(both)
  inviteToken   String    @unique @map("invite_token") // /thiep/<slug>?to=<token>
  maxCompanions Int       @default(1) @map("max_companions")
  viewedAt      DateTime? @map("viewed_at") // lần đầu khách mở link
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  card   Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rsvps  RsvpResponse[]
  wishes Wish[]
  views  CardView[]

  @@index([cardId])
  @@index([inviteToken])
  @@map("guests")
}

/// Phản hồi tham dự (RSVP) — gắn với toàn bộ thiệp, không còn theo từng sự kiện.
model RsvpResponse {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId       String     @map("card_id") @db.Uuid
  guestId      String?    @map("guest_id") @db.Uuid // NULL nếu khách điền trực tiếp không qua link riêng
  guestName    String     @map("guest_name") // tên tự điền, độc lập với Guest.name
  phone        String?
  attending    RsvpStatus
  numAttendees Int        @default(1) @map("num_attendees")
  note         String?
  createdAt    DateTime   @default(now()) @map("created_at")

  card  Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  guest Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([guestId])
  @@map("rsvp_responses")
}

/// Lời chúc (guestbook / tường lời chúc)
model Wish {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId      String   @map("card_id") @db.Uuid
  guestId     String?  @map("guest_id") @db.Uuid
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  message     String
  isApproved  Boolean  @default(true) @map("is_approved") // chủ thiệp duyệt trước khi public
  isHidden    Boolean  @default(false) @map("is_hidden") // ẩn nhưng không xoá
  createdAt   DateTime @default(now()) @map("created_at")

  card  Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  guest Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@map("wishes")
}

// =====================================================================
// 6. ASSETS — media người dùng tải lên
// =====================================================================

model Asset {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  type         AssetType
  url          String
  thumbnailUrl String?   @map("thumbnail_url")
  fileSize     BigInt?   @map("file_size") // bytes
  width        Int? // cho ảnh/video
  height       Int?
  durationMs   Int?      @map("duration_ms") // cho audio/video
  createdAt    DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assets")
}

// =====================================================================
// 7. THỐNG KÊ LƯỢT XEM
// =====================================================================

model CardView {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId    String   @map("card_id") @db.Uuid
  guestId   String?  @map("guest_id") @db.Uuid
  ipHash    String?  @map("ip_hash") // hash IP, không lưu IP thô
  userAgent String?  @map("user_agent")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  card  Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  guest Guest? @relation(fields: [guestId], references: [id], onDelete: SetNull)

  @@index([cardId, viewedAt])
  @@map("card_views")
}
